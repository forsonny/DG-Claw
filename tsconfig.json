{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@dg-claw/ai": ["./packages/ai/src/index.ts"],
			"@dg-claw/ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@dg-claw/ai/*": ["./packages/ai/src/*"],
			"@dg-claw/ai/dist/*": ["./packages/ai/src/*"],
			"@dg-claw/agent": ["./packages/agent/src/index.ts"],
			"@dg-claw/agent/*": ["./packages/agent/src/*"],
			"@dg-claw/coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@dg-claw/coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@dg-claw/coding-agent/*": ["./packages/coding-agent/src/*"],
			"@sinclair/typebox": ["./node_modules/@sinclair/typebox"],
			"@dg-claw/tui": ["./packages/tui/src/index.ts"],
			"@dg-claw/tui/*": ["./packages/tui/src/*"],
			"@dg-claw/web-ui": ["./packages/web-ui/src/index.ts"],
			"@dg-claw/web-ui/*": ["./packages/web-ui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
