{
  "name": "@dg-claw/server",
  "version": "0.1.0",
  "description": "Web gateway server for DG-Claw -- Fastify backend with WebSocket agent streaming and REST APIs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dg-claw-server": "dist/cli.js"
  },
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsgo -p tsconfig.build.json && shx chmod +x dist/cli.js",
    "dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "check": "biome check --write --error-on-warnings ."
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@fastify/websocket": "^12.1.0",
    "@fastify/static": "^8.1.0",
    "@fastify/cookie": "^11.0.2",
    "bcryptjs": "^3.0.2",
    "jsonwebtoken": "^9.0.2",
    "@dg-claw/coding-agent": "0.1.0",
    "@dg-claw/memory": "0.1.0",
    "@dg-claw/sandbox": "0.1.0",
    "@dg-claw/autolearn": "0.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^24.3.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "shx": "^0.4.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forsonny/DG-Claw.git",
    "directory": "packages/server"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
