{
	"name": "@dg-claw/web-ui",
	"version": "0.1.0",
	"description": "Reusable web UI components for AI chat interfaces powered by DG-Claw",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": "./dist/index.js",
		"./app.css": "./dist/app.css"
	},
	"scripts": {
		"clean": "shx rm -rf dist dist-spa",
		"build": "tsc -p tsconfig.build.json && tailwindcss -i ./src/app.css -o ./dist/app.css --minify",
		"build:spa": "vite build",
		"dev": "concurrently --names \"build,example\" --prefix-colors \"cyan,green\" \"tsc -p tsconfig.build.json --watch --preserveWatchOutput\" \"tailwindcss -i ./src/app.css -o ./dist/app.css --watch\" \"npm run dev --prefix example\"",
		"dev:tsc": "concurrently --names \"build\" --prefix-colors \"cyan\" \"tsc -p tsconfig.build.json --watch --preserveWatchOutput\" \"tailwindcss -i ./src/app.css -o ./dist/app.css --watch\"",
		"dev:spa": "vite",
		"check": "biome check --write --error-on-warnings . && tsc --noEmit && cd example && biome check --write --error-on-warnings . && tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@dg-claw/ai": "0.1.0",
		"@dg-claw/tui": "0.1.0",
		"@lit-labs/router": "^0.1.3",
		"@lmstudio/sdk": "^1.5.0",
		"docx-preview": "^0.3.7",
		"jszip": "^3.10.1",
		"lucide": "^0.544.0",
		"ollama": "^0.6.0",
		"pdfjs-dist": "5.4.394",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
	},
	"peerDependencies": {
		"@mariozechner/mini-lit": "^0.2.0",
		"lit": "^3.3.1"
	},
	"devDependencies": {
		"@lit-labs/router": "^0.1.3",
		"@mariozechner/mini-lit": "^0.2.0",
		"@tailwindcss/cli": "^4.0.0-beta.14",
		"@tailwindcss/vite": "^4.2.2",
		"concurrently": "^9.2.1",
		"typescript": "^5.7.3",
		"vite": "^6.3.5",
		"vitest": "^3.1.1"
	},
	"keywords": [
		"ai",
		"chat",
		"ui",
		"components",
		"llm",
		"web-components",
		"mini-lit"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/forsonny/DG-Claw.git",
		"directory": "packages/web-ui"
	}
}
