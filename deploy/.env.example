# ==============================================================================
# DG-Claw VPS Deployment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# ==============================================================================

# ---- Required ----------------------------------------------------------------

# Password for the web interface login
DG_CLAW_PASSWORD=changeme

# Your domain name (must have DNS A record pointing to this VPS IP)
DG_CLAW_DOMAIN=claw.yourdomain.com

# Email for Let's Encrypt certificate notifications
DG_CLAW_ACME_EMAIL=you@example.com

# ---- LLM Provider API Keys (at least one required) --------------------------

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ---- Optional ----------------------------------------------------------------

# Default LLM model (format: provider:model-id)
# DG_CLAW_MODEL=anthropic:claude-sonnet-4-5

# Sandbox container image
# DG_CLAW_SANDBOX_IMAGE=node:20-slim

# Traefik dashboard auth (auto-generated by setup.sh)
# Format: user:bcrypt_hash -- use htpasswd to generate manually
# TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$...
